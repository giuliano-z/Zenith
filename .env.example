# Zenith — plantilla de variables de entorno. Copiá a .env y completá los valores.
# NUNCA commitees el archivo .env real (RS-003).

# Django
# Generá una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-real-secret-key
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=zenith
POSTGRES_USER=zenith
POSTGRES_PASSWORD=change-me-local-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS (frontend dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
